# Ignore node_modules in root and all subfolders
**/node_modules/

# Ignore build outputs
**/dist/
**/.turbo/
**/.next/
**/.output/
**/.vercel/

# Ignore environment variable files
**/.env
**/.env.local
**/.env.*.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Ignore log files
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/log/
**/*.log

# Ignore coverage reports
**/coverage/

# Ignore OS/IDE/editor specific files
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Ignore compiled TypeScript outputs
**/*.tsbuildinfo

# Ignore lock files (if you use one package manager only)
# Uncomment only the one you don’t use:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Ignore test and lint cache
**/.eslintcache
**/.jest/

# Ignore commitlint temp files
.git/COMMIT_EDITMSG
